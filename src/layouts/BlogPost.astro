---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { slug: string };

const { title, description, pubDate, updatedDate, lang = 'en', translation, slug = '' } = Astro.props;
const isChinese = lang === 'zh';
const englishSlug = isChinese ? translation : slug;
const chineseSlug = isChinese ? slug : translation;
const dateLocale = isChinese ? 'zh-CN' : 'en-US';
---

<html lang={lang}>
	<head>
		<BaseHead title={title} description={description} />
		{englishSlug && <link rel="alternate" hreflang="en" href={new URL(`/blog/${englishSlug}/`, Astro.site)} />}
		{chineseSlug && <link rel="alternate" hreflang="zh-CN" href={new URL(`/blog/${chineseSlug}/`, Astro.site)} />}
		{englishSlug && <link rel="alternate" hreflang="x-default" href={new URL(`/blog/${englishSlug}/`, Astro.site)} />}
		<style is:global>
			/* Progress bar */
			#progress-bar {
				position: fixed;
				top: 0;
				left: 0;
				height: 2px;
				width: 100%;
				background: black;
				z-index: 999;
				transform: scaleX(0);
				transform-origin: left center;
				will-change: transform;
			}

			/* Lock font-family so Tailwind/shadcn utilities don't interfere */
			.prose, .prose * {
				font-family: var(--font-atkinson), sans-serif;
			}

			.prose p {
				margin-top: 0;
				margin-bottom: 1.4rem;
				font-size: 1.1rem;
				line-height: 1.8;
				color: #374151;
			}
			.prose p:last-child { margin-bottom: 0; }
			.prose img {
				display: block;
				width: min(100vw - 2rem, 54rem);
				max-width: none;
				margin: 2.75rem 50%;
				transform: translateX(-50%);
				border: 1px solid #e7e5e4;
				border-radius: 0.9rem;
			}

			.prose h2 {
				font-size: 1.4rem;
				font-weight: 700;
				line-height: 1.4;
				margin-top: 2.5rem;
				margin-bottom: 0.6rem;
				color: #111;
			}
			.prose h3, .prose h4 {
				font-size: 1.15rem;
				font-weight: 600;
				line-height: 1.4;
				margin-top: 2rem;
				margin-bottom: 0.5rem;
				color: #222;
			}

			.prose a {
				color: black;
				text-underline-offset: 3px;
			}
			@media (hover: hover) and (pointer: fine) {
				.prose a:hover { opacity: 0.6; }
			}

			/* code stays monospace — intentionally different */
			.prose code {
				font-family: ui-monospace, 'Cascadia Code', monospace;
				font-size: 0.875em;
				background: #f3f4f6;
				padding: 0.15em 0.4em;
				border-radius: 4px;
			}
			.prose pre {
				background: #f3f4f6;
				padding: 1.25rem;
				border-radius: 8px;
				overflow-x: auto;
				margin: 1.5rem 0;
			}
			.prose pre code {
				background: none;
				padding: 0;
				font-size: 0.875rem;
			}

			.prose blockquote {
				border-left: 3px solid #e5e7eb;
				padding-left: 1.25rem;
				color: #6b7280;
				margin: 1.5rem 0;
			}
			.prose hr {
				border: none;
				border-top: 1px solid #e5e7eb;
				margin: 2.5rem 0;
			}

			.language-switcher {
				display: flex;
				gap: 0.4rem;
				align-items: center;
				margin-bottom: 0.75rem;
				font-size: 0.8rem;
				color: #9ca3af;
			}
			.language-switcher a {
				color: #6b7280;
				text-decoration: none;
			}
			@media (hover: hover) and (pointer: fine) {
				.language-switcher a:hover { color: #111; }
			}
			.language-switcher [aria-current="page"] {
				color: #111;
				font-weight: 700;
			}

			/* Key statement paragraphs — bold weight + color only, no size jump */
			.prose p:has(> strong:only-child) {
				color: #111;
				line-height: 1.7;
			}
		</style>
	</head>

	<body style="background: white;">
		<div id="progress-bar"></div>
		<Header />

		<main style="max-width: 44rem; margin: 0 auto; padding: clamp(4.5rem, 9vw, 7rem) 1.5rem 5rem;">
			<article>
				<!-- Post header -->
				<header style="margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid #e5e7eb;">
					{translation && (
						<nav class="language-switcher" aria-label="Language">
							<a href={`/blog/${englishSlug}/`} aria-current={!isChinese ? 'page' : undefined}>English</a>
							<span aria-hidden="true">/</span>
							<a href={`/blog/${chineseSlug}/`} aria-current={isChinese ? 'page' : undefined}>中文</a>
						</nav>
					)}
					<div style="font-size: 0.8rem; color: #9ca3af; display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap;">
						<time>
							{new Intl.DateTimeFormat(dateLocale, { month: 'long', day: 'numeric', year: 'numeric' }).format(new Date(pubDate))}
						</time>
						<span id="reading-time"></span>
						{updatedDate && (
							<span style="font-style: italic;">
								· {isChinese ? '更新于' : 'Updated'} {new Intl.DateTimeFormat(dateLocale, { month: 'long', day: 'numeric', year: 'numeric' }).format(new Date(updatedDate))}
							</span>
						)}
					</div>
					<h1 style="font-family: var(--font-sans); font-size: clamp(2.2rem, 5vw, 3.6rem); font-weight: 620; letter-spacing: -0.045em; line-height: 1.08; color: black; margin: 0; text-wrap: balance;">
						{title}
					</h1>
					{description && (
						<p style="margin-top: 1rem; font-size: 1.1rem; color: #6b7280; line-height: 1.6; margin-bottom: 0;">
							{description}
						</p>
					)}
				</header>

				<!-- Post body -->
				<div class="prose" style="font-size: 1.1rem; line-height: 1.8; color: #374151;">
					<slot />
				</div>
			</article>

			<div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #e5e7eb;">
				<a href="/blog" style="color: black; text-decoration: none; font-weight: 500; font-size: 0.95rem;">
					← {isChinese ? '所有文章' : 'All Writing'}
				</a>
			</div>
		</main>

		<Footer />

		<script>
			// Reading time
			const prose = document.querySelector('.prose');
			if (prose) {
				const text = (prose.textContent ?? '').trim();
				const isChinese = document.documentElement.lang === 'zh';
				const units = isChinese ? text.replace(/\s/g, '').length : text.split(/\s+/).length;
				const mins = Math.max(1, Math.round(units / (isChinese ? 400 : 200)));
				const el = document.getElementById('reading-time');
				if (el) el.textContent = isChinese
					? `约 ${mins} 分钟`
					: `${mins} min read`;
			}

			// Progress bar
			const bar = document.getElementById('progress-bar');
			if (bar) {
				const update = () => {
					const total = document.documentElement.scrollHeight - window.innerHeight;
					const progress = total > 0 ? window.scrollY / total : 0;
					bar.style.transform = `scaleX(${progress})`;
				};
				window.addEventListener('scroll', update, { passive: true });
				update();
			}
		</script>
	</body>
</html>
