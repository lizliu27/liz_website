---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.prose h2, .prose h3, .prose h4 {
				font-weight: 600;
				line-height: 1.3;
				margin-top: 2.5rem;
				margin-bottom: 0.75rem;
				color: black;
			}
			.prose h2 { font-size: 1.5rem; }
			.prose h3 { font-size: 1.25rem; }
			.prose a {
				color: black;
				text-underline-offset: 3px;
			}
			.prose a:hover { opacity: 0.6; }
			.prose code {
				font-size: 0.875em;
				background: #f3f4f6;
				padding: 0.15em 0.4em;
				border-radius: 4px;
			}
			.prose pre {
				background: #f3f4f6;
				padding: 1.25rem;
				border-radius: 8px;
				overflow-x: auto;
				margin: 1.5rem 0;
			}
			.prose pre code {
				background: none;
				padding: 0;
				font-size: 0.875rem;
			}
			.prose blockquote {
				border-left: 3px solid #e5e7eb;
				padding-left: 1.25rem;
				color: #6b7280;
				margin: 1.5rem 0;
			}
			.prose hr {
				border: none;
				border-top: 1px solid #e5e7eb;
				margin: 2.5rem 0;
			}
		</style>
	</head>

	<body style="background: white;">
		<Header />

		<main style="max-width: 48rem; margin: 0 auto; padding: 6rem 1.5rem 4rem;">
			<article>
				<!-- Post header -->
				<header style="margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid #e5e7eb;">
					<time style="font-size: 0.8rem; color: #9ca3af; display: block; margin-bottom: 1rem;">
						{new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).format(new Date(pubDate))}
						{updatedDate && (
							<span style="margin-left: 1rem; font-style: italic;">
								· Updated {new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).format(new Date(updatedDate))}
							</span>
						)}
					</time>
					<h1 style="font-size: clamp(1.75rem, 5vw, 2.5rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2; color: black; margin: 0;">
						{title}
					</h1>
					{description && (
						<p style="margin-top: 1rem; font-size: 1.1rem; color: #6b7280; line-height: 1.6; margin-bottom: 0;">
							{description}
						</p>
					)}
				</header>

				<!-- Post body -->
				<div class="prose" style="font-size: 1.05rem; line-height: 1.8; color: #374151;">
					<slot />
				</div>
			</article>

			<div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid #e5e7eb;">
				<a href="/blog" style="color: black; text-decoration: none; font-weight: 500; font-size: 0.95rem;">
					← All Writing
				</a>
			</div>
		</main>

		<Footer />
	</body>
</html>
