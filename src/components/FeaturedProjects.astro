---
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';

// Per-company accent — subtle, used for the hero metric + left rule when expanded.
const accents: Record<string, string> = {
  Iress: '#2563eb',
  'Commonwealth Bank': '#eab308',
  ByteDance: '#000000',
};

const projects = [
  {
    title: 'Production RAG System',
    company: 'Iress',
    description:
      'Designed and deployed multi-stage RAG with chunking strategies, hybrid retrieval, and reranking to reduce hallucination in production.',
    tags: ['RAG', 'Python', 'Hybrid Retrieval', 'Reranking'],
    metric: 'Multiple production use cases',
    metricLabel: 'deployed RAG systems',
    problem:
      'Generative answers were only as reliable as the evidence retrieved, and retrieval quality varied across documents and use cases.',
    approach:
      'Built a multi-stage retrieval pipeline combining document-aware chunking, hybrid search, and reranking before generation.',
    decision:
      'Treated retrieval as a system with separable stages instead of expecting the language model to compensate for weak evidence.',
  },
  {
    title: 'GenAI Evaluation Harness',
    company: 'Iress',
    description:
      'Built an automated eval pipeline covering test-case generation, multi-dimensional scoring, regression detection, and human-in-the-loop feedback.',
    tags: ['Evaluation', 'DeepEval', 'HITL'],
    metric: 'Test → score → regress',
    metricLabel: 'repeatable evaluation loop',
    problem:
      'Model and prompt changes were difficult to compare consistently when quality depended on ad hoc manual review.',
    approach:
      'Combined automated test-case generation, multi-dimensional scoring, regression detection, and human feedback in one pipeline.',
    decision:
      'Used automated checks for repeatability while keeping human review for ambiguous or high-impact judgments.',
  },
  {
    title: 'LLM Meeting Summarizer',
    company: 'Iress',
    description:
      'LLM-powered system that extracts key client information from meetings and generates structured summaries, cutting manual post-meeting workload.',
    tags: ['LLM', 'Automation', 'Business Impact'],
    metric: 'Transcript → structured output',
    metricLabel: 'less manual follow-up',
    problem:
      'Post-meeting notes required manual synthesis and could miss client details needed by the next workflow.',
    approach:
      'Extracted key client information from meeting transcripts and generated a consistent structured summary for follow-up.',
    decision:
      'Preferred a stable output structure over a purely free-form summary so downstream systems could consume the result reliably.',
  },
  {
    title: 'Customer Churn Propensity Model',
    company: 'Commonwealth Bank',
    description:
      'Led full model lifecycle — training, deployment, monitoring — for churn prediction; converted batch model to real-time inference service.',
    tags: ['PyTorch', 'MLOps', 'Real-time Inference'],
    metric: 'Batch → online',
    metricLabel: 'batch → real-time',
    problem:
      'A batch propensity model could not support applications that needed a prediction at the moment of a customer interaction.',
    approach:
      'Led training, deployment, monitoring, and iteration while converting the model into a scalable online inference service.',
    decision:
      'Redesigned the serving path for online use instead of simply wrapping the existing batch job, with monitoring kept part of the lifecycle.',
  },
  {
    title: 'Advertising Experimentation',
    company: 'ByteDance',
    description:
      'Used causal inference and A/B testing to measure the impact of product and algorithm changes on advertising revenue and user engagement.',
    tags: ['Causal Inference', 'A/B Testing', 'Revenue Impact'],
    metric: 'Causal inference + A/B tests',
    metricLabel: 'evidence for product decisions',
    problem:
      'Observed changes in advertising revenue or engagement could not reliably show whether a product or algorithm change caused the result.',
    approach:
      'Used controlled experiments, causal inference, and multi-dimensional KPI frameworks to evaluate proposed changes.',
    decision:
      'Defined success metrics and guardrails before interpreting results, keeping revenue impact and user engagement visible together.',
  },
];
---

<section class="projects-section">
  <div class="projects-inner">
    <h2 class="projects-label">
      FEATURED PROJECTS
    </h2>
    <div class="projects-grid">
      {projects.map((project, i) => {
        const accent = accents[project.company] ?? '#111';
        return (
          <Card
            className="project-card"
            data-project-card
            style={{ '--accent': accent } as any}
          >
            <CardHeader>
              <p style={{ fontSize: '0.75rem', color: '#9ca3af', margin: '0 0 0.25rem 0' }}>{project.company}</p>
              <CardTitle style={{ fontSize: '1.05rem', lineHeight: '1.4' }}>{project.title}</CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <p style={{ fontSize: '0.9rem', color: '#6b7280', lineHeight: '1.6', marginBottom: 0 }}>{project.description}</p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map(tag => (
                  <Badge variant="secondary" style={{ fontSize: '0.72rem' }}>{tag}</Badge>
                ))}
              </div>

              <!-- Expandable detail -->
              <div class="project-detail" id={`project-detail-${i}`} hidden>
                <div class="project-detail-inner">
                  <div class="project-metric">
                    <span class="project-metric-value">{project.metric}</span>
                    <span class="project-metric-label">{project.metricLabel}</span>
                  </div>
                  <dl class="project-detail-list">
                    <dt>Problem</dt>
                    <dd>{project.problem}</dd>
                    <dt>Approach</dt>
                    <dd>{project.approach}</dd>
                    <dt>Key decision</dt>
                    <dd>{project.decision}</dd>
                  </dl>
                </div>
              </div>

              <button
                type="button"
                class="project-toggle"
                aria-expanded="false"
                aria-controls={`project-detail-${i}`}
              >
                <span class="project-toggle-label">Expand details</span>
                <svg class="project-toggle-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
            </CardContent>
          </Card>
        );
      })}
    </div>
  </div>
</section>

<style>
  .project-card {
    border-color: #e7e5e4;
    border-radius: 0.9rem;
    box-shadow: 0 1px 0 rgba(24, 24, 27, 0.02);
    transition: transform 180ms var(--ease-out), border-color 140ms ease, background-color 140ms ease;
  }
  .projects-section {
    padding: clamp(4.5rem, 8vw, 7rem) 0;
    border-bottom: 1px solid var(--hairline);
  }
  .projects-inner {
    width: min(100% - 3rem, 64rem);
    margin: 0 auto;
  }
  .projects-label {
    margin: 0 0 2rem;
    color: #71717a;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.14em;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  .project-card:first-child {
    grid-column: 1 / -1;
  }

  .project-detail {
    display: block;
  }
  .project-detail[hidden] {
    display: none;
  }
  .project-detail-inner {
    overflow: hidden;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 180ms var(--ease-out), transform 180ms var(--ease-out);
    @starting-style {
      opacity: 0;
      transform: translateY(4px);
    }
  }

  .project-metric {
    border-left: 3px solid var(--accent);
    padding-left: 0.75rem;
    margin: 0.25rem 0 1rem;
  }
  .project-metric-value {
    display: block;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.2;
    color: #111;
  }
  .project-metric-label {
    display: block;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
    margin-top: 0.15rem;
  }

  .project-detail-list {
    margin: 0;
    display: grid;
    gap: 0.15rem;
  }
  .project-detail-list dt {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    font-weight: 600;
    margin-top: 0.7rem;
  }
  .project-detail-list dd {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: #4b5563;
  }

  .project-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: none;
    padding: 0;
    margin-top: 0.25rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: #6b7280;
    cursor: pointer;
    min-height: 2.75rem;
    transition: color 140ms ease, transform 140ms var(--ease-out);
  }
  .project-toggle:active { transform: scale(0.97); }
  .project-toggle-icon {
    transition: transform 160ms var(--ease-out);
  }
  .project-toggle[aria-expanded='true'] .project-toggle-icon {
    transform: rotate(180deg);
  }

  @media (hover: hover) and (pointer: fine) {
    .project-card:hover { transform: translateY(-2px); border-color: #d6d3d1; background: #fdfdfc; }
    .project-toggle:hover { color: #111; }
  }
  @media (max-width: 700px) {
    .projects-inner { width: min(100% - 2rem, 64rem); }
    .projects-grid { grid-template-columns: 1fr; }
    .project-card:first-child { grid-column: auto; }
  }
</style>

<script>
  function setupProjectCards() {
    const cards = document.querySelectorAll<HTMLElement>('[data-project-card]');
    cards.forEach(card => {
      const toggle = card.querySelector<HTMLButtonElement>('.project-toggle');
      const detail = card.querySelector<HTMLElement>('.project-detail');
      const label = card.querySelector<HTMLElement>('.project-toggle-label');
      if (!toggle || !detail || !label) return;

      const open = () => {
        detail.hidden = false;
        toggle.setAttribute('aria-expanded', 'true');
        label.textContent = 'Collapse';
      };
      const close = () => {
        detail.hidden = true;
        toggle.setAttribute('aria-expanded', 'false');
        label.textContent = 'Expand details';
      };
      const toggleFn = () => {
        if (toggle.getAttribute('aria-expanded') === 'true') close();
        else open();
      };

      toggle.addEventListener('click', e => {
        e.stopPropagation();
        toggleFn();
      });
    });
  }

  setupProjectCards();
  document.addEventListener('astro:page-load', setupProjectCards);
</script>
