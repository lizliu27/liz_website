---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.filter((post) => post.data.lang !== 'zh')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main class="writing-index">
			<header class="writing-header">
				<p>WRITING</p>
				<h1>Notes on building AI systems—and thinking clearly about them.</h1>
			</header>

			<div class="post-list">
				{posts.map(post => (
					<article class="post-row">
						<a href={`/blog/${post.id}/`}>
							<div>
							<time>
								{new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).format(new Date(post.data.pubDate))}
							</time>
							<h2>
								{post.data.title}
							</h2>
							{post.data.description && (
								<p>
									{post.data.description}
								</p>
							)}
							</div>
							<span class="post-arrow" aria-hidden="true">↗</span>
						</a>
					</article>
				))}
			</div>
		</main>

		<Footer />
	</body>
</html>

<style>
	.writing-index { width: min(100% - 3rem, 50rem); margin: 0 auto; padding: clamp(5rem, 10vw, 8rem) 0 6rem; }
	.writing-header { max-width: 43rem; margin-bottom: 4rem; }
	.writing-header > p { margin: 0 0 1.25rem; color: #71717a; font-family: var(--font-sans); font-size: 0.72rem; font-weight: 650; letter-spacing: 0.14em; }
	.writing-header h1 { margin: 0; font-family: var(--font-sans); font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 610; letter-spacing: -0.055em; line-height: 1.03; text-wrap: balance; }
	.post-list { border-top: 1px solid var(--hairline); }
	.post-row { border-bottom: 1px solid var(--hairline); }
	.post-row a { padding: 2rem 0; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 2rem; align-items: center; color: inherit; text-decoration: none; }
	.post-row time { display: block; margin-bottom: 0.65rem; color: #a1a1aa; font-family: var(--font-sans); font-size: 0.75rem; }
	.post-row h2 { max-width: 30ch; margin: 0; font-family: var(--font-sans); font-size: clamp(1.35rem, 3vw, 1.85rem); font-weight: 610; letter-spacing: -0.03em; line-height: 1.24; }
	.post-row p { max-width: 62ch; margin: 0.75rem 0 0; color: #71717a; font-size: 0.98rem; line-height: 1.65; }
	.post-arrow { color: #a1a1aa; font-size: 1.1rem; transition: transform 180ms var(--ease-out), color 140ms ease; }
	@media (hover: hover) and (pointer: fine) {
		.post-row a:hover .post-arrow { color: #111; transform: translate(2px, -2px); }
	}
	@media (max-width: 640px) {
		.writing-index { width: min(100% - 2rem, 50rem); }
		.post-row a { gap: 1rem; }
	}
</style>
