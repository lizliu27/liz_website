---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Terms of Use | Liz Liu" description="Terms of use for liz-website-rouge.vercel.app." />
  </head>
  <body style="background: white;">
    <Header />
    <main style="max-width: 38rem; margin: 0 auto; padding: 5rem 1.5rem 4rem;">
      <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 2rem;">Terms of Use</h1>
      <p style="color: #6b7280; font-size: 0.85rem; margin-bottom: 2rem;">Last updated: April 2026</p>

      <section style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.75rem;">Content</h2>
        <p style="color: #374151; line-height: 1.7;">All content on this site — including writing, project descriptions, and code examples — is the original work of Liz Liu unless otherwise noted. You may quote or reference it with attribution.</p>
      </section>

      <section style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.75rem;">Disclaimer</h2>
        <p style="color: #374151; line-height: 1.7;">This site is provided as-is for informational purposes. The views expressed are personal and do not represent any employer. No warranty is made regarding accuracy or completeness.</p>
      </section>

      <section style="margin-bottom: 2rem;">
        <h2 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.75rem;">Contact</h2>
        <p style="color: #374151; line-height: 1.7;">Questions? <a href="mailto:lizliu627@gmail.com" style="color: black; text-decoration: underline;">lizliu627@gmail.com</a></p>
      </section>
    </main>
    <Footer />
  </body>
</html>
