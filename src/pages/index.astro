---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import FeaturedProjects from '../components/FeaturedProjects.astro';
import ContactStrip from '../components/ContactStrip.astro';
const allPosts = await getCollection('blog');
const latestPosts = allPosts
	.filter((post) => post.data.lang !== 'zh')
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>
      <section class="home-hero">
        <div class="home-shell hero-grid">
          <div>
            <p class="eyebrow"><span class="status-dot" aria-hidden="true"></span> Liz Liu · Data Scientist</p>
            <h1>Building AI systems that hold up in the real world.</h1>
            <p class="hero-copy">
              I work across GenAI, experimentation, and product decisions—turning complex models into systems people can trust and outcomes businesses can measure.
            </p>
            <div class="hero-actions">
              <a href="/blog" class="button button-primary">Read my writing <span aria-hidden="true">↗</span></a>
              <a href="https://www.linkedin.com/in/liz-liu-a0b149167/" target="_blank" rel="noopener noreferrer" class="button button-secondary">Connect on LinkedIn</a>
            </div>
          </div>
          <aside class="hero-notes" aria-label="Current role and experience">
            <div class="note-row"><span>Now</span><strong>Iress · Singapore</strong></div>
            <div class="note-row"><span>Previously</span><strong>Commonwealth Bank · ByteDance · ING</strong></div>
            <div class="note-row"><span>Focus</span><strong>GenAI systems · Evaluation · Experimentation</strong></div>
          </aside>
        </div>
        <div class="home-shell skill-line" aria-label="Tools and methods">
          {['Python', 'SQL', 'RAG', 'LangGraph', 'PyTorch', 'GCP'].map(tech => <span>{tech}</span>)}
        </div>
      </section>

      <FeaturedProjects />

      <section class="writing-section">
        <div class="home-shell section-heading-row">
          <p class="section-label">LATEST WRITING</p>
          <a href="/blog" class="text-link">View all <span aria-hidden="true">↗</span></a>
        </div>
        <div class="home-shell writing-list">
          {latestPosts.map(post => (
            <article class="writing-row">
              <a href={`/blog/${post.id}/`}>
                <div>
                  <time>{new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(new Date(post.data.pubDate))}</time>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.description}</p>
                </div>
                <span class="row-arrow" aria-hidden="true">↗</span>
              </a>
            </article>
          ))}
        </div>
      </section>

      <ContactStrip />
    </main>

    <Footer />
  </body>
</html>

<style>
  .home-shell { width: min(100% - 3rem, 64rem); margin-inline: auto; }
  .home-hero { padding: clamp(5rem, 11vw, 8.5rem) 0 2rem; border-bottom: 1px solid var(--hairline); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.65fr) minmax(16rem, 0.7fr); gap: clamp(3rem, 8vw, 7rem); align-items: end; }
  .eyebrow, .section-label { margin: 0; font-family: var(--font-sans); font-size: 0.72rem; font-weight: 650; letter-spacing: 0.14em; text-transform: uppercase; color: #71717a; }
  .eyebrow { display: flex; align-items: center; gap: 0.6rem; }
  .status-dot { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #22c55e; box-shadow: 0 0 0 4px #f0fdf4; }
  .home-hero h1 { max-width: 13ch; margin: 1.4rem 0 0; font-family: var(--font-sans); font-size: clamp(3.25rem, 7.6vw, 6.25rem); font-weight: 620; letter-spacing: -0.065em; line-height: 0.98; text-wrap: balance; }
  .hero-copy { max-width: 36rem; margin: 2rem 0 0; color: #52525b; font-size: clamp(1.05rem, 1.8vw, 1.22rem); line-height: 1.65; }
  .hero-actions { margin-top: 2.25rem; display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .button { min-height: 3rem; padding: 0 1.15rem; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; border: 1px solid #111; border-radius: 0.7rem; text-decoration: none; font-size: 0.9rem; font-weight: 650; transition: transform 140ms var(--ease-out), background-color 140ms ease, color 140ms ease; }
  .button:active { transform: scale(0.97); }
  .button-primary { background: #111; color: white; }
  .button-secondary { background: white; color: #111; }
  .hero-notes { border-top: 1px solid #d6d3d1; }
  .note-row { padding: 1rem 0; display: grid; gap: 0.2rem; border-bottom: 1px solid var(--hairline); }
  .note-row span { color: #a1a1aa; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; }
  .note-row strong { color: #3f3f46; font-size: 0.86rem; line-height: 1.5; font-weight: 550; }
  .skill-line { margin-top: clamp(4rem, 8vw, 6rem); padding-top: 1.25rem; display: flex; flex-wrap: wrap; gap: 0.65rem 1.35rem; border-top: 1px solid var(--hairline); color: #a1a1aa; font-family: var(--font-sans); font-size: 0.75rem; }
  .writing-section { padding: clamp(4.5rem, 8vw, 7rem) 0; border-bottom: 1px solid var(--hairline); }
  .section-heading-row { display: flex; align-items: center; justify-content: space-between; gap: 2rem; margin-bottom: 2rem; }
  .text-link { color: #52525b; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: color 140ms ease; }
  .writing-list { border-top: 1px solid var(--hairline); }
  .writing-row { border-bottom: 1px solid var(--hairline); }
  .writing-row > a { padding: 1.75rem 0; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 2rem; align-items: center; color: inherit; text-decoration: none; }
  .writing-row time { display: block; margin-bottom: 0.6rem; color: #a1a1aa; font-family: var(--font-sans); font-size: 0.72rem; letter-spacing: 0.04em; }
  .writing-row h2 { max-width: 28ch; margin: 0; font-family: var(--font-sans); font-size: clamp(1.3rem, 2.2vw, 1.7rem); line-height: 1.25; letter-spacing: -0.025em; }
  .writing-row p { max-width: 55ch; margin: 0.65rem 0 0; color: #71717a; line-height: 1.6; }
  .row-arrow { color: #a1a1aa; font-size: 1.1rem; transition: transform 180ms var(--ease-out), color 140ms ease; }
  @media (hover: hover) and (pointer: fine) {
    .button-primary:hover { background: #27272a; }
    .button-secondary:hover { background: #fafaf9; }
    .text-link:hover { color: #111; }
    .writing-row a:hover .row-arrow { color: #111; transform: translate(2px, -2px); }
  }
  @media (max-width: 760px) {
    .home-shell { width: min(100% - 2rem, 64rem); }
    .hero-grid { grid-template-columns: 1fr; }
    .hero-grid { gap: 3.5rem; }
    .home-hero h1 { font-size: clamp(3rem, 15vw, 5rem); }
    .writing-row > a { gap: 1rem; }
  }
</style>
